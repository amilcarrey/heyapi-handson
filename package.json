{
  "name": "@amilcarrey/faker-openapi-sdk",
  "version": "0.1.0",
  "description": "Auto-generated TypeScript SDK from a synthetic OpenAPI spec (openapi-trigger-faker). Sandbox for @hey-api/openapi-ts + oasdiff + cross-repo regen.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "codegen": "openapi-ts",
    "typecheck": "tsc --noEmit",
    "example": "tsx examples/basic.ts",
    "example:zod": "tsx examples/with-zod.ts"
  },
  "peerDependencies": {
    "@hey-api/client-fetch": "^0.13.1",
    "@tanstack/react-query": "^5.0.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    }
  },
  "devDependencies": {
    "@hey-api/client-fetch": "^0.13.1",
    "@hey-api/openapi-ts": "^0.97.1",
    "@tanstack/react-query": "^5.100.10",
    "@types/node": "^25.8.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "zod": "^4.4.3"
  },
  "packageManager": "pnpm@10.11.0"
}
